FROM golang:1.26-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" \
    -o /out/alert-evaluator ./cmd/alert-evaluator

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/alert-evaluator /alert-evaluator
ENTRYPOINT ["/alert-evaluator"]
CMD ["run"]
